# Copia a `.env` y edita (no subas secretos reales).

# --- Imágenes oficiales (Docker Hub) — fija versión para builds reproducibles ---
IMAGE_KAFKA=apache/kafka:4.1.2
IMAGE_INFLUXDB=influxdb:2.8.0
IMAGE_SPARK=spark:4.1.1-python3
# Grafana: el tag corto "13.1.0" a menudo NO existe en Hub; copia desde Tags el build completo (inmutable).
# Evita "main"/"nightly" para el laboratorio (cambian cada día). "latest" es aceptable si no necesitas reproducir builds.
IMAGE_GRAFANA=grafana/grafana:13.1.0-24753821026

# Kafka KRaft: ID de clúster estable (no cambiar si reutilizas el volumen kafka_data)
KAFKA_CLUSTER_ID=4L6g3nShT-eMCtK--X86sw

# Publicación en el host del listener PLAINTEXT_HOST (dentro del contenedor sigue siendo 9092)
KAFKA_PORT=9092
KAFKA_ADVERTISED_EXTERNAL_HOST=localhost
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092

# Bootstrap: desde tu PC → 127.0.0.1:${KAFKA_PORT}
#             desde otro contenedor en la misma red → kafka:19092

# InfluxDB 2 (init solo con volumen vacío)
INFLUXDB_PORT=8086
INFLUX_USERNAME=admin
INFLUX_PASSWORD=changeme_influx
INFLUX_ORG=canary-maritime
INFLUX_BUCKET=ship-metrics
INFLUX_ADMIN_TOKEN=dev-token-change-me

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana

# --- Procesamiento Spark (opcional) ---
# Lista de puertos para Haversine en el job PySpark (si no se define, usa src/processing/data/canary_ports.json)
# CANARY_PORTS_JSON_PATH=C:/ruta/a/tus_puertos.json

# Modo de salida Spark: console | influx | both
SPARK_OUTPUT_MODE=console

# Sink InfluxDB desde Spark
INFLUXDB_URL=http://127.0.0.1:8086
INFLUX_MEASUREMENT=ships_positions
INFLUX_BATCH_SIZE=500
INFLUX_FLUSH_INTERVAL_MS=1000

# Umbral de alerta para la UI web (nudos)
WEB_SPEED_ALERT_KNOTS=25
